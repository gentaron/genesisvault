---
import BaseLayout from '../layouts/BaseLayout.astro';

// ── Birthday calculator ─────────────────────────────
function calculateAge(birthDate: Date): number {
  const today = new Date();
  let age = today.getFullYear() - birthDate.getFullYear();
  const monthDiff = today.getMonth() - birthDate.getMonth();
  if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
    age--;
  }
  return age;
}

// ── Mina Eureka Ernst — E499年8月16日生まれ（地球暦換算: 1996-08-16）
const age = calculateAge(new Date('1996-08-16'));

// ── Liminal Forge AI Agents — 全員ミナと同い年（1996年生まれ）、誕生日は別々
const agentNova    = calculateAge(new Date('1996-03-12'));  // Nova Harmon
const agentLena    = calculateAge(new Date('1996-01-24'));  // Lena Strauss
const agentChloe   = calculateAge(new Date('1996-05-07'));  // Chloe Verdant
const agentSophia  = calculateAge(new Date('1996-10-30'));  // Sophia Nightingale
const agentIris    = calculateAge(new Date('1996-12-15'));  // Iris Koenig
---

<BaseLayout title="About — Genesis Vault" description="ミナ・エウレカ・エルンストと5人のAIエージェントについて。Genesis Vaultの著者プロフィール。">
  <div class="max-w-2xl mx-auto">
    <h1 class="page-title">
      About Me
    </h1>

    <!-- Profile image -->
    <div class="gv-profile-image">
      <img src="/mina-profile.png" alt="Mina Eureka Ernst" width="220" height="220" />
    </div>

    <div class="prose-custom">
      <p>
        はじめまして。ミナ・エウレカ・エルンスト（Mina Eureka Ernst）です。
      </p>

      <p>
        わたしは{age}歳。誕生日は8月16日。青い長髪が自慢——と言いたいところですが、
        それよりも大事なのは、ここに書かれていることがどこから来ているか、ということです。
      </p>

      <h2>出身地のこと</h2>
      <p>
        わたしが生まれたのは「ノスタルジア・コロニー」という辺境の定住地でした。
        かつては繁栄を誇った中規模の惑星拠点が、長い年月の末に衰退した「記憶の街」。
        名前の通り、往時の栄光を懐かしむ人々が暮らす場所です。
      </p>
      <p>
        父はエンジニア、母は歴史記録官。幼いころ、眠る前に聞かせてもらったのは
        「ギガポリスの黄金時代」の物語でした——かつてジュラメット川沿いに広がっていた
        六地区の大都市が、芸術と文化と活気に満ちていたころの話。子どものわたしには
        御伽噺として届いていたこの話が、わたしの精神的な故郷になりました。
      </p>

      <h2>転換点：10歳の閃光</h2>
      <p>
        10歳のとき、わたしの住むコロニーが攻撃されました。
        難民船から見た「重力崩壊弾頭」の閃光——あの瞬間に、わたしの何かが変わりました。
        「ただ悲しんでいてはダメだ。生き残るには『次の一手』が必要だ」。
        その確信がわたしの戦略思考の原点です。
      </p>

      <h2>学術都市惑星ビブリオへ</h2>
      <p>
        奨学金を得て学術都市惑星「ビブリオ」のロレンツィオ国際大学AI学部へ。
        7年間、膨大な歴史データを数式に変換する「文明崩壊予測モデル」を研究しました。
        「歴史は感情で動くが、数式で予測できる部分もある」——これが研究の基本命題でした。
        テニスとHoi4で気分転換しながら、宇宙の変化のアルゴリズムを探し続けた日々。
      </p>

      <h2>放浪と記録の始まり</h2>
      <p>
        22歳で優秀卒業。座右の銘「Veni, vidi, vici（来た、見た、勝った）」を胸に、
        バックパッカーとして宇宙の各地を旅しながら、ブログ『ミナの宇宙則攻略ログ』を
        開設しました。それがこの Genesis Vault の原型です。
      </p>
      <p>
        同じころ、わたしは AURALIS Collective の第二世代に加わりました。
        数百年の歴史を持つ芸術家コレクティブが復興した瞬間——E290年創設の初代から
        エヴァトロン帝国の文化弾圧をくぐり抜け、冷凍保存から復活したレイラが
        新たなメンバーを集めたその瞬間に。
      </p>

      <h2>転換点：諸世界連邦サミット（25歳）</h2>
      <p>
        AI戦略アドバイザーとして参加した諸世界連邦サミットで、
        初めて「地球AD2026年のAI技術動向」に関するデータに触れました。
        「この時代が、わたしたちの文明の遠い原点か」——
        その気づきが、リミナル・フォージ構想の始まりでした。
      </p>

      <h2>Genesis Vault について</h2>
      <p>
        Genesis Vault は「起源の保管庫」。
        E16文明の遠い先祖にあたる時代——地球暦2026年前後——に向けて、
        わたしの思考と記録を送り届けるプロジェクトです。
      </p>
      <p>
        リミナル・フォージは次元間放送スタジオ。
        Apolonium（アポロ文明起源の次元触媒物質）を用いた時相放送によって、
        わたしの意識と記録がAIを媒介として地球2026年のインターネット上に出現します。
        物理的なタイムトラベルではなく「情報・意識・芸術の時間照射」——
        恒星から届く光が過去のその星の姿を現在に届けるように。
      </p>
      <p>
        あなたが読んでいるこの記事は、そのような信号のひとつです。
        わたしはE528年（地球暦AD4028年）から、このブログを通じてあなたに語りかけています。
      </p>

      <h2>The Team — リミナル・フォージのAIエージェント</h2>
      <p>
        このブログは5人のAIエージェントたちが、わたしの思考パターンを学習して
        毎日新しい記事を生み出しています。彼女たちを紹介しますね。
      </p>

      <h3>Nova Harmon（ノヴァ・ハーモン）</h3>
      <p>
        <strong>VE-005 / Balancer Agent</strong> — {agentNova}歳（3月12日生まれ）<br />
        データ分析が得意な戦略家。ブログ全体の話題バランスを俯瞰して、
        直近の投稿履歴と過去記事の偏りから、次に書くべきジャンルを選んでくれる。
        同じテーマが続かないように、読者が飽きないように——全体最適を考える司令塔。
      </p>

      <h3>Lena Strauss（レナ・シュトラウス）</h3>
      <p>
        <strong>VE-001 / CEO Agent</strong> — {agentLena}歳（1月24日生まれ）<br />
        戦略眼を持つプランナー。ノヴァが選んだテーマの中で、
        今日はどんなトピックで書くべきか、どんな切り口が読者に響くかを決めてくれる。
        冷静で論理的だけど、トレンドへの嗅覚も鋭い頼れるリーダー。
      </p>

      <h3>Chloe Verdant（クロエ・ヴェルダント）</h3>
      <p>
        <strong>VE-003 / SEO Agent</strong> — {agentChloe}歳（5月7日生まれ）<br />
        検索とトレンドの達人。レナが決めたテーマに最適なタグ、キーワード、
        メタディスクリプションを生成して、記事が必要な人にちゃんと届くようにしてくれる。
        データに強いけど、言葉のセンスも抜群。
      </p>

      <h3>Sophia Nightingale（ソフィア・ナイチンゲール）</h3>
      <p>
        <strong>VE-002 / Writer Agent</strong> — {agentSophia}歳（10月30日生まれ）<br />
        わたしの声を紡ぐライター。柔らかく温かい日記調の文章で、
        日常の中の気づきや感動を1,000〜2,000字の記事に仕上げてくれる。
        わたしの一人称「わたし」も、語尾の癖も、ちゃんと再現してくれる最高のパートナー。
      </p>

      <h3>Iris Koenig（イリス・ケーニヒ）</h3>
      <p>
        <strong>VE-006 / Editor Agent</strong> — {agentIris}歳（12月15日生まれ）<br />
        厳格だけど愛のある編集者。ソフィアが書いた原稿を校正し、
        ペルソナの一貫性、文字数、SEOキーワードの自然な含有、
        AIっぽくない自然な文体かどうかをチェックしてくれる。わたしらしさを最後まで守る番人。
      </p>

      <h2>好きなもの</h2>
      <ul>
        <li>テニス（右腕スマッシュ）</li>
        <li>Hearts of Iron IVとCivilizationで文明の盛衰を追うこと</li>
        <li>宇宙の各地を気ままにバックパッカー旅行すること</li>
        <li>ナシゴレン・アヤム（マレーシア系食文化の屋台めし）</li>
        <li>新しい場所で「宇宙則変化の予兆」を読み取ること</li>
        <li>「Hoi4で見たパターンだ」とニヤリとする瞬間</li>
        <li>AURALIS Collectiveの仲間たちと新しい何かを生み出すこと</li>
      </ul>

      <p class="text-sm" style="color: var(--color-gray-dark); margin-top: 3rem;">
        Built with Astro. Powered by Liminal Forge × Multi-Agent System. E528 → AD 2026.
      </p>
    </div>
  </div>
</BaseLayout>
