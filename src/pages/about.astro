---
import BaseLayout from '../layouts/BaseLayout.astro';

// ── Mina Eureka Ernst's birthday ─────────────────────
// 2026年8月16日に30歳になる → 誕生日: 1996-08-16
const BIRTH_DATE = new Date('1996-08-16');

function calculateAge(birthDate: Date): number {
  const today = new Date();
  let age = today.getFullYear() - birthDate.getFullYear();
  const monthDiff = today.getMonth() - birthDate.getMonth();
  if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
    age--;
  }
  return age;
}

const age = calculateAge(BIRTH_DATE);
---

<BaseLayout title="About — Genesis Vault" description="ミナ・エウレカ・エルンストと5人のAIエージェントについて。Genesis Vaultの著者プロフィール。">
  <div class="max-w-2xl mx-auto">
    <h1 class="page-title">
      About Me
    </h1>

    <!-- Profile image -->
    <div class="gv-profile-image">
      <img src="/mina-profile.png" alt="Mina Eureka Ernst" width="220" height="220" />
    </div>

    <div class="prose-custom">
      <p>
        はじめまして。ミナ・エウレカ・エルンスト（Mina Eureka Ernst）です。
      </p>

      <p>
        わたしは{age}歳の独身女性。デジタルノマド的な暮らしを楽しみながら、
        この Genesis Vault に日々の思考や気づきを綴っています。
        誕生日は8月16日。
      </p>

      <h2>わたしのこと</h2>
      <p>
        コツコツ貯金するのが好きで、投資にも興味がある。
        暗号通貨や株式ETFで長期目線の資産形成に取り組んでいます。
        独身ライフを満喫しながら、自分だけの時間を大切にしている毎日です。
      </p>
      <p>
        週末はふらっとプチ旅行に出かけたり、気になっていた本を読んだり。
        毎朝の瞑想とジャーナリングはわたしの日課で、
        散歩しながら考えをまとめるのも好きな時間です。
      </p>

      <h2>わたしが書くこと</h2>
      <p>
        貯金や投資のリアル、ひとり旅で見つけたもの、読んだ本の感想、
        瞑想やジャーナリングで得た気づき、散歩道で拾った思考のかけら——
        独身で、自分のペースで生きることを楽しんでいる人に
        「わかる」と感じてもらえるような記事を書いています。
      </p>

      <h2>Genesis Vault について</h2>
      <p>
        Genesis Vault は「始まりの保管庫」という意味を込めた、わたしのパーソナルブログです。
        すべての思考や気づきには「始まり」がある——その種を大切に保管しておきたいという想いから名付けました。
      </p>
      <p>
        このブログは5人のAIエージェントたちが、わたしの思考パターンを学習して
        毎日新しい記事を生み出しています。彼女たちを紹介しますね。
      </p>

      <h2>The Team — 5人のAIエージェント</h2>

      <h3>Nova Harmon（ノヴァ・ハーモン）</h3>
      <p>
        <strong>VE-005 / Balancer Agent</strong><br />
        データ分析が得意な戦略家。ブログ全体の話題バランスを俯瞰して、
        直近の投稿履歴と過去記事の偏りから、次に書くべきジャンルを選んでくれる。
        同じテーマが続かないように、読者が飽きないように——全体最適を考える司令塔。
      </p>

      <h3>Lena Strauss（レナ・シュトラウス）</h3>
      <p>
        <strong>VE-001 / CEO Agent</strong><br />
        戦略眼を持つプランナー。ノヴァが選んだテーマの中で、
        今日はどんなトピックで書くべきか、どんな切り口が読者に響くかを決めてくれる。
        冷静で論理的だけど、トレンドへの嗅覚も鋭い頼れるリーダー。
      </p>

      <h3>Chloe Verdant（クロエ・ヴェルダント）</h3>
      <p>
        <strong>VE-003 / SEO Agent</strong><br />
        検索とトレンドの達人。レナが決めたテーマに最適なタグ、キーワード、
        メタディスクリプションを生成して、記事が必要な人にちゃんと届くようにしてくれる。
        データに強いけど、言葉のセンスも抜群。
      </p>

      <h3>Sophia Nightingale（ソフィア・ナイチンゲール）</h3>
      <p>
        <strong>VE-002 / Writer Agent</strong><br />
        わたしの声を紡ぐライター。柔らかく温かい日記調の文章で、
        日常の中の気づきや感動を1,000〜2,000字の記事に仕上げてくれる。
        わたしの一人称「わたし」も、語尾の癖も、ちゃんと再現してくれる最高のパートナー。
      </p>

      <h3>Iris Koenig（イリス・ケーニヒ）</h3>
      <p>
        <strong>VE-006 / Editor Agent</strong><br />
        厳格だけど愛のある編集者。ソフィアが書いた原稿を校正し、
        ペルソナの一貫性、文字数、SEOキーワードの自然な含有、
        AI っぽくない自然な文体かどうかをチェックしてくれる。わたしらしさを最後まで守る番人。
      </p>

      <h2>好きなもの</h2>
      <ul>
        <li>コツコツ貯金して残高が増えていく瞬間</li>
        <li>ETFの積立グラフを眺めること</li>
        <li>週末のプチ旅行で知らない町を歩くこと</li>
        <li>カフェの窓際で読書する時間</li>
        <li>朝の瞑想で心を整えること</li>
        <li>ジャーナリングで思考を書き出すこと</li>
        <li>夕暮れの散歩</li>
      </ul>

      <p class="text-sm" style="color: var(--color-gray-dark); margin-top: 3rem;">
        Built with Astro. Powered by Gemini API + Multi-Agent System. Hosted on Vercel.
      </p>
    </div>
  </div>
</BaseLayout>
