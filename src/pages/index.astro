---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Genesis Vault with Mina Eureka Ernst">
  <div class="mb-16 text-center">
    <h1 class="page-title">
      Genesis Vault
    </h1>
    <p class="subtitle">
      with Mina Eureka Ernst
    </p>
    <p class="text-lg" style="color: var(--color-gray-dark); margin-top: 0.75rem;">
      思考の種を保管する、静かなデジタル日記
    </p>
  </div>

  <!-- Wallet Connect Card -->
  <div class="gv-wallet-card">
    <div class="gv-wallet-card-header">
      <div class="gv-wallet-card-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z" fill="none" />
          <path d="M12 5.36L8.87 8.5a3.13 3.13 0 0 0 0 4.43L12 16.07" opacity="0.5" />
        </svg>
      </div>
      <div>
        <p class="gv-wallet-card-title">Ethereum Wallet</p>
        <p class="gv-wallet-card-sub">3 USDC で全記事をアンロック</p>
      </div>
    </div>
    <div id="wallet-area">
      <button id="btn-connect" class="gv-btn-connect">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="6" width="20" height="12" rx="2" />
          <path d="M22 10H18C16.9 10 16 10.9 16 12C16 13.1 16.9 14 18 14H22" />
        </svg>
        ウォレットを接続
      </button>
    </div>
  </div>

  <div class="grid gap-8" id="post-list">
    {sortedPosts.map((post, index) => (
      <div class="gv-post-item" data-index={index}>
        <PostCard post={post} />
      </div>
    ))}
  </div>

  <!-- Locked overlay (hidden by default, shown by JS) -->
  <div id="locked-section" class="gv-locked-section" style="display:none;">
    <div class="gv-locked-overlay">
      <div class="gv-locked-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
      </div>
      <p class="gv-locked-text">
        残り <strong id="locked-count">0</strong>件 の記事がロックされています
      </p>
      <p class="gv-locked-subtext">
        3 USDC で全コンテンツをアンロック
      </p>
    </div>
  </div>

  {sortedPosts.length === 0 && (
    <div class="text-center py-20">
      <p style="color: var(--color-gray-dark);">まだ記事がありません</p>
    </div>
  )}

  <script is:inline>
    (function() {
      var STORAGE_KEY = 'gv_paid_status';
      var FREE_LIMIT = 2;
      var ETH_RECEIVE = '0x94Ac0Cbf9188E31979Ad1434d86Cdc75ddBEc10c';
      var USDC_CONTRACT = '0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48';
      var USDC_AMOUNT = 3;
      var USDC_DECIMALS = 1000000;
      var MAINNET_CHAIN_ID = '0x1';
      var REQUIRED_CONFIRMATIONS = 2;
      var POLL_INTERVAL_MS = 3000;
      var POLL_MAX_ATTEMPTS = 40;

      // Prevent concurrent payment attempts
      var paymentInProgress = false;

      function isValidAddress(addr) {
        return typeof addr === 'string' && /^0x[0-9a-fA-F]{40}$/.test(addr);
      }

      function isValidTxHash(hash) {
        return typeof hash === 'string' && /^0x[0-9a-fA-F]{64}$/.test(hash);
      }

      // Server-side payment status: check via cookie (set by /api/verify-payment)
      function isServerPaid() {
        return document.cookie.indexOf('gv_token=') !== -1;
      }

      // Local cache (secondary, for instant page loads)
      function isLocalPaid() {
        try {
          var raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return false;
          var d = JSON.parse(raw);
          return d.paid === true &&
                 isValidTxHash(d.txHash) &&
                 isValidAddress(d.wallet) &&
                 typeof d.timestamp === 'number' &&
                 d.chain === 'ethereum';
        } catch(e) { return false; }
      }

      function isPaid() {
        // Server cookie is source of truth; localStorage is secondary cache
        return isServerPaid() || isLocalPaid();
      }

      function markPaid(wallet, txHash) {
        if (!isValidTxHash(txHash) || !isValidAddress(wallet)) return;

        // Server-side verification: call /api/verify-payment
        fetch('/api/verify-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ txHash: txHash, wallet: wallet })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.verified) {
            // Server set the gv_token cookie; update localStorage cache
            localStorage.setItem(STORAGE_KEY, JSON.stringify({
              paid: true,
              wallet: wallet.toLowerCase(),
              chain: 'ethereum',
              txHash: txHash,
              timestamp: Date.now()
            }));
            applyPaywall();
          } else {
            var payBtn = document.getElementById('btn-pay');
            var errEl = document.getElementById('pay-error');
            showPayError(payBtn, errEl, 'サーバー検証に失敗しました: ' + (data.error || '不明なエラー'));
          }
        })
        .catch(function(err) {
          // Fallback to localStorage-only if server unreachable
          console.warn('Server verification failed, falling back to localStorage:', err);
          localStorage.setItem(STORAGE_KEY, JSON.stringify({
            paid: true,
            wallet: wallet.toLowerCase(),
            chain: 'ethereum',
            txHash: txHash,
            timestamp: Date.now()
          }));
          applyPaywall();
        });
      }

      // Poll eth_getTransactionReceipt until confirmed or timeout
      function waitForReceipt(txHash, onSuccess, onError) {
        var attempts = 0;
        function poll() {
          if (attempts >= POLL_MAX_ATTEMPTS) {
            onError('タイムアウト: トランザクションを手動でご確認ください。(TX: ' + txHash.slice(0, 10) + '...)');
            return;
          }
          attempts++;
          window.ethereum.request({ method: 'eth_getTransactionReceipt', params: [txHash] })
            .then(function(receipt) {
              if (!receipt) { setTimeout(poll, POLL_INTERVAL_MS); return; }

              // Transaction reverted on-chain
              if (receipt.status === '0x0' || receipt.status === 0) {
                onError('トランザクションが失敗しました。USDC残高とガス代をご確認ください。');
                return;
              }

              // Verify the transaction was sent to USDC contract
              if (!receipt.to || receipt.to.toLowerCase() !== USDC_CONTRACT.toLowerCase()) {
                onError('不正なトランザクションが検出されました。');
                return;
              }

              window.ethereum.request({ method: 'eth_blockNumber', params: [] })
                .then(function(blockHex) {
                  var txBlock = parseInt(receipt.blockNumber, 16);
                  var currentBlock = parseInt(blockHex, 16);
                  if (currentBlock - txBlock + 1 >= REQUIRED_CONFIRMATIONS) {
                    onSuccess();
                  } else {
                    setTimeout(poll, POLL_INTERVAL_MS);
                  }
                })
                .catch(function() { setTimeout(poll, POLL_INTERVAL_MS); });
            })
            .catch(function() { setTimeout(poll, POLL_INTERVAL_MS); });
        }
        setTimeout(poll, POLL_INTERVAL_MS);
      }

      function applyPaywall() {
        var paid = isPaid();
        var items = document.querySelectorAll('.gv-post-item');
        var lockedCount = 0;

        items.forEach(function(item, i) {
          if (!paid && i >= FREE_LIMIT) {
            item.style.display = 'none';
            lockedCount++;
          } else {
            item.style.display = '';
          }
        });

        var lockedSection = document.getElementById('locked-section');
        var lockedCountEl = document.getElementById('locked-count');
        if (!paid && lockedCount > 0) {
          lockedCountEl.textContent = lockedCount;
          lockedSection.style.display = '';
        } else {
          lockedSection.style.display = 'none';
        }

        var walletArea = document.getElementById('wallet-area');
        if (paid && walletArea) {
          walletArea.innerHTML = '<div class="gv-wallet-paid"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> 全コンテンツアクセス済み</div>';
        }
      }

      function showPayError(payBtn, errEl, msg) {
        paymentInProgress = false;
        errEl.textContent = msg;
        errEl.style.display = '';
        payBtn.textContent = '3 USDC で全コンテンツをアンロック';
        payBtn.disabled = false;
      }

      function handlePayment(addr) {
        if (paymentInProgress) return;

        var payBtn = document.getElementById('btn-pay');
        var errEl = document.getElementById('pay-error');
        if (!payBtn || !errEl) return;

        paymentInProgress = true;
        errEl.style.display = 'none';
        payBtn.textContent = 'ネットワーク確認中...';
        payBtn.disabled = true;

        // Verify user is on Ethereum mainnet before proceeding
        window.ethereum.request({ method: 'eth_chainId' })
          .then(function(chainId) {
            if (chainId !== MAINNET_CHAIN_ID) {
              showPayError(payBtn, errEl, 'Ethereumメインネット (Chain ID: 1) に切り替えてください。');
              return;
            }

            payBtn.textContent = '処理中...';

            var rawAmount = USDC_AMOUNT * USDC_DECIMALS;
            var toHex = ETH_RECEIVE.slice(2).toLowerCase().padStart(64, '0');
            var amountHex = rawAmount.toString(16).padStart(64, '0');
            var data = '0xa9059cbb' + toHex + amountHex;

            window.ethereum.request({
              method: 'eth_sendTransaction',
              params: [{ from: addr, to: USDC_CONTRACT, data: data }]
            })
            .then(function(txHash) {
              if (!isValidTxHash(txHash)) {
                showPayError(payBtn, errEl, 'ウォレットから無効な応答を受け取りました。再試行してください。');
                return;
              }

              payBtn.textContent = 'ブロック確認中... (数分かかる場合があります)';

              waitForReceipt(
                txHash,
                function() {
                  markPaid(addr, txHash);
                  paymentInProgress = false;
                  applyPaywall();
                },
                function(errMsg) {
                  showPayError(payBtn, errEl, errMsg);
                }
              );
            })
            .catch(function(err) {
              if (err && err.code === 4001) {
                showPayError(payBtn, errEl, 'キャンセルされました。');
              } else {
                showPayError(payBtn, errEl, '送金処理中にエラーが発生しました。再試行してください。');
              }
            });
          })
          .catch(function() {
            showPayError(payBtn, errEl, 'ネットワーク情報の取得に失敗しました。再試行してください。');
          });
      }

      function renderWalletPanel(addr) {
        var walletArea = document.getElementById('wallet-area');
        var short = addr.slice(0, 6) + '...' + addr.slice(-4);

        walletArea.innerHTML =
          '<div class="gv-wallet-panel">' +
            '<div class="gv-wallet-info">' +
              '<span class="gv-wallet-dot"></span>' +
              '<span class="gv-wallet-addr">' + short + '</span>' +
              '<button id="btn-disconnect" class="gv-btn-small">Disconnect</button>' +
            '</div>' +
            '<div class="gv-wallet-card-divider"></div>' +
            '<button id="btn-pay" class="gv-btn-pay">' +
              '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' +
              '3 USDC で全コンテンツをアンロック' +
            '</button>' +
            '<p id="pay-error" class="gv-error" style="display:none;"></p>' +
          '</div>';

        document.getElementById('btn-disconnect').addEventListener('click', function() {
          var wa = document.getElementById('wallet-area');
          wa.innerHTML =
            '<button id="btn-connect-2" class="gv-btn-connect">' +
              '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<rect x="2" y="6" width="20" height="12" rx="2" />' +
                '<path d="M22 10H18C16.9 10 16 10.9 16 12C16 13.1 16.9 14 18 14H22" />' +
              '</svg>' +
              'ウォレットを接続' +
            '</button>';
          document.getElementById('btn-connect-2').addEventListener('click', handleConnectClick);
        });

        document.getElementById('btn-pay').addEventListener('click', function() {
          handlePayment(addr);
        });
      }

      function handleConnectClick() {
        if (!window.ethereum) {
          alert('MetaMaskなどのEthereum対応ウォレットをインストールしてください。');
          return;
        }
        window.ethereum.request({ method: 'eth_requestAccounts' })
          .then(function(accounts) {
            var addr = accounts[0];
            if (!isValidAddress(addr)) {
              alert('ウォレットから無効なアドレスを受け取りました。');
              return;
            }
            renderWalletPanel(addr);
          })
          .catch(function(err) {
            if (err && err.code !== 4001) {
              alert('ウォレット接続に失敗しました。再試行してください。');
            }
          });
      }

      var btnConnect = document.getElementById('btn-connect');
      if (btnConnect) {
        btnConnect.addEventListener('click', handleConnectClick);
      }

      // On page load: verify payment via server-side cookie
      // If server cookie exists, ensure localStorage cache is in sync
      if (isServerPaid() && !isLocalPaid()) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          paid: true,
          wallet: '',
          chain: 'ethereum',
          txHash: '',
          timestamp: Date.now(),
          serverVerified: true
        }));
      }

      applyPaywall();
    })();
  </script>
</BaseLayout>
