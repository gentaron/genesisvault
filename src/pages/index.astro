---
import BaseLayout from '../layouts/BaseLayout.astro';
import PaywalledContent from '../components/PaywalledContent';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Serialize post data for the React component
const postsData = sortedPosts.map(post => ({
  slug: post.slug,
  title: post.data.title,
  date: post.data.date.toISOString(),
  mood: post.data.mood || '',
  weather: post.data.weather || '',
  tags: post.data.tags || [],
  description: post.data.description || '',
}));
---

<BaseLayout title="Genesis Vault with Mina Eureka Ernst">
  <div class="mb-16 text-center">
    <h1 class="page-title">
      Genesis Vault
    </h1>
    <p class="subtitle">
      with Mina Eureka Ernst
    </p>
    <p class="text-lg" style="color: var(--color-gray-dark); margin-top: 0.75rem;">
      思考の種を保管する、静かなデジタル日記
    </p>
  </div>

  <PaywalledContent client:only="react" posts={postsData} />
</BaseLayout>
