---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.draft !== true);
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  // Determine which posts are free (newest 2) based on the sorted index
  const FREE_LIMIT = 2;
  return sorted.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      postIndex: index,
      isFree: index < FREE_LIMIT,
    },
  }));
}

const { post, postIndex, isFree } = Astro.props;
const { title, date, mood, weather, tags, description, keywords, agents, gated } = post.data;
const isGated = gated !== false && !isFree;

// Only render body component for free (non-gated) posts in the static HTML
let BodyComponent;
if (!isGated) {
  const { Content } = await post.render();
  BodyComponent = Content;
}

const formattedDate = new Date(date).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long'
});
---

<BaseLayout
  title={`${title} — Genesis Vault`}
  description={description}
  keywords={keywords}
>
  <head>
    {isGated && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <article class="max-w-2xl mx-auto" style="max-width: 42rem; margin: 0 auto;">
    <header style="margin-bottom: 3rem; text-align: center;">
      <time datetime={date.toISOString()} class="text-sm" style="color: var(--color-gray-dark); display: block; margin-bottom: 1rem;">
        {formattedDate}
      </time>

      <h1 class="page-title" style="margin-bottom: 1.5rem;">
        {title}
      </h1>

      <div style="display: flex; justify-content: center; align-items: center; gap: 1rem; color: var(--color-gray-dark);">
        {mood && <span style="font-size: 1.5rem;">{mood}</span>}
        {weather && <span style="font-size: 1.5rem;">{weather}</span>}
      </div>

      {tags.length > 0 && (
        <div class="tags" style="justify-content: center; margin-top: 1.5rem;">
          {tags.map((tag: string) => (
            <span class="tag">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {isGated ? (
      <!-- GATED: Body fetched client-side from /api/article/[slug] -->
      <div id="article-body" data-slug={post.slug}>
        <div class="gv-post-paywall-gate">
          <div class="gv-locked-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          </div>
          <h3 class="gv-gate-title">この記事はプレミアムコンテンツです</h3>
          <p class="gv-gate-description">3 USDC で全ての記事にアクセスできます</p>
          <a href="/" class="gv-btn-connect" style="display:inline-flex; text-decoration:none;">
            ホームからアンロック
          </a>
        </div>
      </div>
    ) : (
      <!-- FREE: Body rendered statically -->
      <div id="post-content" data-post-index={postIndex}>
        <div class="prose-custom">
          {BodyComponent && <BodyComponent />}
        </div>
        {agents && (
          <div class="agent-badge" style="margin-top: 2rem; padding: 1rem; border-radius: 0.5rem; background: var(--color-soft-beige); font-size: 0.8rem; color: var(--color-gray-dark);">
            <p style="margin-bottom: 0.5rem;"><strong>Generated by Multi-Agent Pipeline</strong></p>
            <span>CEO: {agents.ceo}</span> &middot;
            <span>SEO: {agents.seo}</span> &middot;
            <span>Writer: {agents.writer}</span> &middot;
            <span>Editor: {agents.editor}</span>
          </div>
        )}
      </div>
    )}

    <footer style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--color-gray-light);">
      <a href="/" style="color: var(--color-gentle-green);">
        &larr; Home
      </a>
    </footer>
  </article>

  {isGated && (
    <script is:inline>
      (function() {
        var slug = document.getElementById('article-body').getAttribute('data-slug');
        fetch('/api/article/' + encodeURIComponent(slug), { credentials: 'include' })
          .then(function(r) {
            if (r.status === 200) return r.text();
            return null;
          })
          .then(function(html) {
            if (html) {
              var el = document.getElementById('article-body');
              el.innerHTML = '<div class="prose-custom">' + html + '</div>';
            }
            // If 402/401, the gate UI stays visible — user needs to pay
          });
      })();
    </script>
  )}
</BaseLayout>
