# ═══════════════════════════════════════════════════════════
# Genesis Vault — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# At minimum, GEMINI_API_KEY is required for the AI pipeline.
# Additional providers serve as fallback chain (Phase γ).
# Total monthly cost: 0 yen (free-tier only).
# ═══════════════════════════════════════════════════════════

# ─── Primary AI Provider ────────────────────────────────────
# Google Gemini (free tier): 15 RPM / 1000 RPD (flash-lite), 10 RPM / 250 RPD (flash)
# Required for the daily auto-post pipeline.
GEMINI_API_KEY=

# ─── Fallback Providers (optional, free-tier only) ─────────
# Groq (free tier): ~30 RPM / ~14400 RPD — llama-3.3-70b-versatile
GROQ_API_KEY=

# Cerebras (free tier): ~30 RPM — llama-3.3-70b
CEREBRAS_API_KEY=

# OpenRouter (free tier): ~20 RPM — meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_KEY=

# HuggingFace Inference (free tier): variable limits
HF_TOKEN=

# ─── Web3 / Paywall ────────────────────────────────────────
# Ethereum mainnet paywall contract address
PAYMENT_CONTRACT_ADDRESS=

# WalletConnect Project ID (for multi-wallet support)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Nostr / IPFS ──────────────────────────────────────────
# Nostr signing key (nsec format)
NOSTR_PRIVATE_KEY=

# Pinata IPFS API keys
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# ─── Observability ─────────────────────────────────────────
# Sentry DSN (optional)
PUBLIC_SENTRY_DSN=
