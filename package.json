{
  "name": "gensnotes-diary-2026",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && node scripts/build-search.mjs",
    "build:search": "node scripts/build-search.mjs",
    "preview": "bun run build && wrangler dev",
    "astro": "astro",
    "auto-post": "bun scripts/auto-post.mjs",
    "gen:dry": "DRY_RUN=true bun scripts/auto-post.mjs",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@ai-sdk/cerebras": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/groq": "^2.0.0",
    "@ai-sdk/huggingface": "^1.0.48",
    "@astrojs/check": "^0.9.0",
    "@astrojs/cloudflare": "12",
    "@astrojs/mdx": "^4.0.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@sentry/astro": "^10.0.0",
    "@vercel/node": "^3.0.0",
    "ai": "^5.0.0",
    "astro": "^5.0.0",
    "nostr-tools": "^2.10.0",
    "typescript": "^5.8.0",
    "viem": "^2.48.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "pagefind": "^1.3.0",
    "tailwindcss": "^4.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0",
    "zod": "^4.4.3"
  }
}
